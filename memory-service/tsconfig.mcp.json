{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2022",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": "dist/mcp",
    "declaration": false,
    "sourceMap": false,
    "isolatedModules": false,
    "jsx": "react",
    "types": ["node"]
  },
  "include": [
    "src/mcp/**/*",
    "src/memory/**/*",
    "src/domain/**/*",
    "src/server/**/*"
  ],
  "exclude": ["node_modules", ".next", "dist", "tests"]
}
