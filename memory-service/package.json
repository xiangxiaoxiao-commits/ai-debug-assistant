{
  "name": "ai-memory-service",
  "version": "0.5.0",
  "private": true,
  "description": "Local-first memory service for AI agents. HTTP + MCP + SDK.",
  "scripts": {
    "dev": "next dev -p 8788",
    "build": "next build",
    "start": "next start -p 8788",
    "build:mcp": "node scripts/build-mcp.mjs",
    "mcp": "node dist/mcp/memory-server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "package": "node scripts/package.mjs"
  },
  "dependencies": {
    "next": "15.0.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "3.23.8",
    "uuid": "9.0.1"
  },
  "devDependencies": {
    "@types/node": "20.16.10",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.0",
    "@types/uuid": "9.0.8",
    "typescript": "5.6.3",
    "vitest": "1.6.0"
  }
}
